# PAX GROUP Backend — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# ── TEMEL ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret — min 64 karakter rastgele string
# Üretmek için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# Allowed frontend origin (CORS)
FRONTEND_URL=https://www.paxgroupglobal.com
BACKEND_URL=https://your-backend.onrender.com

# ── AI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
AI_PROVIDER=openai

# ── MESAJLAŞMA KANALLARI ───────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
VIBER_BOT_TOKEN=

# ── OPSİYONEL ─────────────────────────────────────────
# n8n otomasyon webhook
# N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/xxx
# WEBHOOK_SECRET=replace_with_a_strong_random_secret
